APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# file is safer for workers (queue restart flag); database needs healthy MySQL first
CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# VK parser microservice (Docker service name on the laravel network)
PARSER_URL=http://parser:3000
PARSER_TIMEOUT=180

# VK scan automation (Phase 5)
VK_SCAN_LIMIT=6
VK_SCAN_WITH_COMMENTS=true
VK_SCAN_GROUP_DELAY_SECONDS=45

# Telegram bot (Bot API) — irazasyed/telegram-bot-sdk
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: extra chats for commands (comma-separated). Defaults to TELEGRAM_CHAT_ID.
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_NOTIFY_ENABLED=true
# Full URL or base https URL (ngrok public host). Path /api/telegram/webhook is appended if missing.
TELEGRAM_WEBHOOK_URL=
# Optional secret for X-Telegram-Bot-Api-Secret-Token
TELEGRAM_WEBHOOK_SECRET=

# Optional: ngrok for local webhook development
NGROK_AUTHTOKEN=
NGROK_API_URL=http://ngrok:4040
